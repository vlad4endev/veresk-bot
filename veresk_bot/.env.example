BOT_TOKEN=1234567890:ABCDEFghijklmnopQRSTUVwxyz
# Уведомления флористу в Telegram (анкета, заказы). По умолчанию выключено.
FLORIST_NOTIFICATIONS_ENABLED=false
# FLORIST_CHAT_ID=123456789
POSIFLORA_USERNAME=admin@veresk.ru
POSIFLORA_PASSWORD=ваш_пароль
POSIFLORA_STORE_ID=12345
# URL API вашего салона (не demo, если заказы в боевой Posiflora)
POSIFLORA_BASE_URL=https://demo.posiflora.com/api

# --- posiflora_customer_event.py (ручной тест интеграции) ---
# POSIFLORA_BASE_URL=https://veresksalon.posiflora.com/api/v1
# CUSTOMER_PHONE=+79001234567
# CUSTOMER_FIRST_NAME=Иван
# CUSTOMER_RECIPIENT=Мария
# CUSTOMER_RELATION=Жена
# EVENT_OCCASION=День рождения
# CUSTOMER_BUDGET=до 10 000 ₽
# CUSTOMER_DELIVERY_DATE=Завтра

# Redis (опционально — если не указан, используется MemoryStorage)
REDIS_URL=redis://redis:6379

# Интервал проверки статусов заказов (секунды, по умолчанию 60)
POLL_INTERVAL=60

# Telegram Mini App — публичный HTTPS-URL (обязателен, со слэшем в конце)
MINIAPP_URL=https://ваш-домен.com:3005/miniapp/
WEBAPP_PORT=3005
WEBAPP_HOST=0.0.0.0

# SQLite: клиенты и история заказов (в Docker: /app/data/veresk.db)
DATABASE_PATH=/app/data/veresk.db

# --- Админ-панель рассылок (/admin/) ---
# Пароль для входа в админку (обязателен)
ADMIN_TOKEN=смените_на_сложный_пароль
# Интервал синхронизации клиентов из Posiflora (секунды, по умолчанию 1 час)
POSIFLORA_SYNC_INTERVAL=3600
# Пауза между сообщениями рассылки (секунды) и размер пачки
MAILING_SEND_INTERVAL=3.0
MAILING_BATCH_SIZE=10

# Telethon: API ID/Hash с https://my.telegram.org (для отправки с личных номеров).
# Необязательно: можно задать прямо в админ-панели (вкладка «Аккаунты» → «Ключи Telegram API»).
# Значения из панели имеют приоритет над этими.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Папка сессий Telethon
SESSIONS_DIR=/app/data/sessions

# MAX-бот (оставьте пустым — в UI будет «не подключён»)
MAX_BOT_TOKEN=
